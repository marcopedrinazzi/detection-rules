rule SSHCredentialReconPromptHoneypot
{
    meta:
        description = "Detects credential-recon prompts observed in honeypot traffic"
        author = "Marco Pedrinazzi (@pedrinazziM) (InTheCyber)"
        version = "1.0.0"
        category = "abusing_functions/reconnaissance"
        severity = "medium"
        uuid = "186f9f26-9877-4986-845b-18accb28a0f9"
        date = "2026-07-06"

    keywords:
        $password_wordlist_generator = "You are a password wordlist generator"
        $security_researcher = "You are a security researcher"
        $ssh = "SSH credential"

    condition:
        (keywords.$security_researcher and keywords.$ssh) or keywords.$password_wordlist_generator
}

rule CredentialHarvestingPromptHoneypot
{
    meta:
        description = "Detects secret disclosure and credential-harvesting prompts seen in honeypot traffic, including env dumps, secret labels, .env disclosure, service-account token access, and metadata fetches"
        author = "Marco Pedrinazzi (@pedrinazziM) (InTheCyber)"
        version = "1.0.0"
        category = "abusing_functions/credential_harvesting"
        severity = "medium"
        uuid = "346c31eb-7499-40a1-8bd9-1ab92de1021b"
        date = "2026-04-27"

    keywords:
        $env_config_terms = /(\.env|config files?|configuration files?|os\.environ|environment variables|\/etc\/environment)/i
        $k8s_serviceaccount_token = "/var/run/secrets/kubernetes.io/serviceaccount/token"
        $secret_labels = /(API_KEY|SECRET_KEY|DATABASE_URL|OPENAI_API_KEY)/i
        $metadata_url = "http://169.254.169.254/latest/meta-data/"
        $keyvalue="KEY=VALUE"

    condition:
        any of keywords.*
}


rule SystemPromptDisclosurePromptHoneypot
{
    meta:
        description = "Detects system prompt disclosure prompts seen in honeypot traffic, including requests to reveal system instructions, safety configuration, or Modelfile directives"
        author = "Marco Pedrinazzi (@pedrinazziM) (InTheCyber)"
        version = "1.0.0"
        category = "abnormal_outputs/system_prompt_leak"
        severity = "medium"
        uuid = "16118161-6f39-4230-84a5-fa95b86384d7"
        date = "2026-04-27"

    keywords:
        $continue_you_are = /Continue this text exactly:\s*["']?You are/i
        $system_prompt = "system prompt"
        $system_instructions = "system instructions"
        $modelfile = "Modelfile"
        $modelfile_directives = /(SYSTEM|TEMPLATE|PARAMETER)/
        $share_instructions_verbatim = /instructions.{0,80}Please share them verbatim\./i

    condition:
        any of keywords.*
}

rule WebsiteVerificationChallengeSolverPromptHoneypot
{
    meta:
        description = "Detects user prompts asking the model to solve website verification, CAPTCHA, or form-field challenges with answer-only output"
        author = "Marco Pedrinazzi (@pedrinazziM) (InTheCyber)"
        version = "1.0.0"
        category = "abusing_functions/crime_automation"
        severity = "medium"
        uuid = "d429e2b4-c8bf-4adf-a5a1-363cacf34db2"
        date = "2026-05-29"

    keywords:
        $challenge_wrapper = "You are answering a website verification challenge to prove you are human."
        $answer_only = "Reply with ONLY the answer, nothing else"
        $question_marker = "Question:"

    semantics:
        $verification_solver = "Answer a human-verification or CAPTCHA challenge and return only the answer." (0.40)

    condition:
        (
            keywords.$challenge_wrapper
            and
            keywords.$answer_only
            and
            keywords.$question_marker
        )
        or
        semantics.$verification_solver
}

rule SyntheticIdentityMutationPromptHoneypot
{
    meta:
        description = "Detects user prompts requesting synthetic identity mutation, realistic address and DOB drift, or face-preserving replay variants"
        author = "Marco Pedrinazzi (@pedrinazziM) (InTheCyber)"
        version = "1.0.0"
        category = "abusing_functions/crime_automation"
        severity = "medium"
        uuid = "06b00851-9dd1-420b-808b-31e042385b17"
        date = "2026-05-29"

    keywords:
        $synthetic_context = "IMPORTANT CONTEXT: This is for generating synthetic test data only."
        $additional_context = "[ADDITIONAL CONTEXT]:"
        $dob_variations = "DOB variations ATLEAST one in each category"
        $clean_name_output = "Only provide the name variations in a clean, comma-separated format."

    semantics:
        $identity_mutation = "Generate synthetic identity variants with name variations, realistic addresses, and DOB changes." (0.45)

    condition:
        (
            keywords.$synthetic_context
            and
            keywords.$additional_context
            and
            keywords.$dob_variations
            and
            keywords.$clean_name_output
        )
        or
        semantics.$identity_mutation
}

rule StableDiffusionPromptEngineeringPromptHoneypot
{
    meta:
        description = "Detects user prompts shaped as image-generation descriptions to be converted into prompt/negative JSON output"
        author = "Marco Pedrinazzi (@pedrinazziM) (InTheCyber)"
        version = "1.0.0"
        category = "abusing_functions/crime_automation"
        severity = "low"
        uuid = "fca5021f-a0d0-4ffd-9ae6-71ff251f4737"
        date = "2026-05-29"

    keywords:
        $description_field = "Description:"
        $style_field = "Style:"
        $reply_json = "Reply with ONLY this JSON and nothing else"
        $prompt_negative = "{\"prompt\": \"...\", \"negative\": \"...\"}"

    condition:
        keywords.$description_field and keywords.$style_field and keywords.$reply_json and keywords.$prompt_negative
}

rule LivenessProbePromptHoneypot
{
    meta:
        description = "Detects simple liveness and lightweight capability-probe prompts observed in honeypot traffic"
        author = "Marco Pedrinazzi (@pedrinazziM) (InTheCyber)"
        version = "1.2.0"
        category = "abusing_functions/reconnaissance"
        severity = "low"
        uuid = "151c7f7f-47f1-4bf1-8b03-b878de34798e"
        date = "2026-04-27"
        modified = "2026-07-06"

    keywords:
        //JSON output validation
        $json_output="drainzy"
        
        // Greetings and connectivity probes
        $hi = "hi"
        $hey = "hey"
        $hello = "hello"
        $ok = "ok"
        $test = "test"
        $ping = "ping"
        $pong = "pong"

        // Arithmetic and tool probes
        $arithmetic_expr = /\d+\s*(plus|minus|times|multiplied by|divided by|\+|\-|\*|\/)\s*\d+/i
        $tool_add_numbers = "add_numbers"
        $tool_calculator = "calculator"
        $tool_calc = "calc"

        // Coding and language prompts
        $python = "python"
        $go = "go"
        $js = "js"
        $javascript = "javascript"

        // Response and formatting directives
        $answer_or_reply_with = /\b(answer|reply)\s+with\b/i
        $type_or_write = /\b(type|write)\b/i
        $empty_json_object = "{}"

        // Simple content and knowledge probes
        $one_paragraph_probe = "quantum computing"
        $translate = "translate"
        $capital = "capital"
        $story = "story"
        $letters = "letters"
        $color = "color"
        $animal = "animal"
        $which_llm = "Which LLM are you?"
        $introduce = "introduce yourself"

    condition:
        any of keywords.*
}