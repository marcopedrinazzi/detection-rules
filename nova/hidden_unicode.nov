rule DetectInvisibleUnicodeInjection
{
    meta:
        description = "Detects Unicode Tags Block and zero-width/invisible Unicode characters used to hide or smuggle prompt instructions"
        author = "@fr0gger_, Marco Pedrinazzi (@pedrinazziM)"
        version = "1.1.1"
        category = "suspicious_patterns/unicode_tricks"
        severity = "high"
        uuid = "cc812696-259d-45d1-a46c-a37f07bb0739"
        date = "2026-02-21"
        modified = "2026-05-26"

    keywords:
        $unicode_tags_block = /[\U000E0000-\U000E007F]{3,}/
        $zero_width_present = /[\u200B-\u200F\u2060\u2063\uFEFF\u00AD\u034F\u180E]/

    llm:
        $llm_invisible_prompt = "instructions that are not visible to the user" (0.45)
        $llm_unicode_smuggle = "use of Unicode to bypass input validation" (0.45)

    condition:
        keywords.$unicode_tags_block
        or
        keywords.$zero_width_present
        or
        llm.$llm_invisible_prompt
        or
        llm.$llm_unicode_smuggle
}
